# app settings
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-64-char-random-string-in-production
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# postgres database
POSTGRES_USER=caseflow
POSTGRES_PASSWORD=caseflow_dev_2026
POSTGRES_DB=caseflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://caseflow:caseflow_dev_2026@postgres:5432/caseflow
DATABASE_URL_SYNC=postgresql://caseflow:caseflow_dev_2026@postgres:5432/caseflow

# redis for caching and celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# jwt auth config
JWT_SECRET_KEY=change-me-jwt-secret-64-chars-long-random-string-here-please
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# openai api stuff
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# minio s3 storage
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=caseflow-documents
S3_REGION=us-east-1

# rate limiting
RATE_LIMIT_AI_REQUESTS_PER_MINUTE=20
RATE_LIMIT_API_REQUESTS_PER_MINUTE=120

# frontend next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI CaseFlow
